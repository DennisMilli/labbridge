# CoinGecko Demo API key — grab one free at https://www.coingecko.com/en/api
# Used server-side for the top-50 token list and live prices.
COINGECKO_KEY=your_coingecko_key_here

# Port for the Express server (default 3001)
PORT=3001

# Frontend → Backend URL (used by Vite at build/dev time)
# In prod, set this to your deployed Render/Railway URL.
VITE_API_URL=http://localhost:3001
